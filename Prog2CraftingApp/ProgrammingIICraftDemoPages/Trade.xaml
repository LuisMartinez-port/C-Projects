<Page x:Class="ProgrammingIICraftDemoPages.Trade"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProgrammingIICraftDemoPages"
      mc:Ignorable="d" 
       d:DesignHeight="400" d:DesignWidth="592"
      Title="Trade">

    <Grid Loaded="Grid_Loaded">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="28,37,343,12">
            <TextBlock x:Name="Output"  TextWrapping="Wrap" Text="Trade"/>
        </ScrollViewer>
        <TextBox x:Name="ConfirmItemTextBox" HorizontalAlignment="Left" Margin="370,323,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="156" Height="50"/>
        <Button x:Name="SwitchToCrafted" Content="SwitchToCraftedInventory" Margin="370,278,66,82" Click="SwitchToCrafted_Click"/>
        <Button x:Name="SellButton" Content="Sell" HorizontalAlignment="Left" Height="33" Margin="286,340,0,0" VerticalAlignment="Top" Width="79" Click="SellButton_Click"/>
        <Button x:Name="BuyButton" Content="Buy" HorizontalAlignment="Left" Height="33" Margin="286,340,0,0" VerticalAlignment="Top" Width="79" Click="BuyButton_Click"/>
        <TextBlock x:Name="errorbox" HorizontalAlignment="Left" Margin="370,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center" Height="90" Width="156"/>


    </Grid>
</Page>
