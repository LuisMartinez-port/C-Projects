<Page x:Class="ProgrammingIICraftDemoPages.Craft"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProgrammingIICraftDemoPages"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="592"
      Title="Craft">

    <Grid Loaded="Grid_Loaded">
        <ScrollViewer Width="300" Height="376" VerticalScrollBarVisibility="Auto" Margin="10,14,282,10">
            <TextBlock x:Name="Output"  TextWrapping="Wrap" Text="Craft" />
        </ScrollViewer>
        <Button x:Name="CraftButton" Content="Craft" HorizontalAlignment="Left" Height="40" Margin="409,264,0,0" VerticalAlignment="Top" Width="140" Click="CraftButton_Click"/>
        <TextBox x:Name="RecipeSelector" HorizontalAlignment="Left" Margin="409,182,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="140" Height="40"/>
        <TextBlock x:Name="descriptor" HorizontalAlignment="Left" Margin="418,85,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="131" Text="Please enter the # of the recipe you would like to craft!"/>
        <TextBlock x:Name="errorbox" HorizontalAlignment="Left" Margin="406,331,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="30" Width="146"/>

    </Grid>
</Page>
