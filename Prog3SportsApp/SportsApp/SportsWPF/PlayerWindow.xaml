<Window x:Class="SportsWPF.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SportsWPF"
        xmlns:uc="clr-namespace:SportsWPF.UserControls"
        mc:Ignorable="d"
        Title="PlayerWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <uc:Nav></uc:Nav>

            <Separator Margin="10"></Separator>
            <StackPanel>
                <uc:UCPlayer x:Name="PlayerControl"></uc:UCPlayer>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
