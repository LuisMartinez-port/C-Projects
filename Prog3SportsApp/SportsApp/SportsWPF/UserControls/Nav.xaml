<UserControl x:Class="SportsWPF.UserControls.Nav"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SportsWPF.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.CommandBindings>
        <CommandBinding Command="New" CanExecute="NewCommand_CanExecute" Executed="NewCommand_Executed" />
        <CommandBinding Command="Open" CanExecute="OpenCommand_CanExecute" Executed="OpenCommand_Executed" />
        <CommandBinding Command="Save" CanExecute="SaveCommand_CanExecute" Executed="SaveCommand_Executed" />
        <CommandBinding Command="SaveAs" CanExecute="SaveCommand_CanExecute" Executed="SaveCommand_Executed" />

    </UserControl.CommandBindings>
    <Grid>
        <StackPanel>
            
            <StackPanel Orientation="Horizontal" Height="20">
                <Button x:Name="btnNavAdmin" Command="{Binding AdminCommand}" Click="btnNavAdmin_Click_1"  >Admin</Button>
                <Separator Margin="10"></Separator>
                <Button x:Name="btnNavTeams" Click="btnNavTeams_Click">Teams</Button>
                <Separator Margin="10"></Separator>
                <Button x:Name="btnNavPlayer" Click="btnNavPlayer_Click">Players</Button>
                <Separator Margin="10"></Separator>
                <Button x:Name="btnNavSched" Click="btnNavSched_Click" >Schedule</Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
