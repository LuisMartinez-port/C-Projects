<Window x:Class="SportsWPF.TeamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SportsWPF"
        mc:Ignorable="d"
        xmlns:uc="clr-namespace:SportsWPF.UserControls"
        Title="TeamWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <uc:Nav></uc:Nav>
            <Separator Margin="10"></Separator>
            <StackPanel>
                <Label>Add Player to Practice Team</Label>
                <ComboBox x:Name="cbTeamSport" ItemsSource="{Binding Sports}" SelectedItem="{Binding SelectedSport}" DisplayMemberPath="Name"/>
                <StackPanel Orientation="Horizontal">
                    <StackPanel>
                        <Label>Sport Players</Label>
                        <ListBox x:Name="lbSportPlayers" ItemsSource="{Binding SportPlayers}" DisplayMemberPath="Name">
                            <!-- Items will be populated based on selected sport -->
                        </ListBox>
                    </StackPanel>
                    <StackPanel>
                        <Label>Practice Team Players</Label>
                        <ListBox x:Name="lbPracticeTeamPlayers" ItemsSource="{Binding PracticeTeamPlayers}" DisplayMemberPath="Name">
                            <!-- Items will be populated based on selected sport -->
                        </ListBox>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label>Player Name:</Label>
                    <TextBox x:Name="tbTeamPlayerName" Width="200" Text="{Binding NewPlayerName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label>Player Number:</Label>
                    <TextBox x:Name="tbTeamPlayerNumber" Width="200" Text="{Binding NewPlayerNumber, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <Button x:Name="btnTeamAddPlayer" Content="Add Player to Practice Team" Command="{Binding AddPlayerCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
